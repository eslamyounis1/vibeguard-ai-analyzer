{
  "name": "vibeguard-analyzer",
  "displayName": "VibeGuard Analyzer",
  "description": "Security analyzer, sandbox profiling, and OWASP-aware secure code chat.",
  "version": "0.2.0",
  "publisher": "vibeguard",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:python",
    "onView:vibeguard.chatView",
    "onCommand:vibeguard.openChat"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vibeguard.analyze",
        "title": "VibeGuard: Analyze File (Security + Sandbox)",
        "icon": "$(shield)"
      },
      {
        "command": "vibeguard.analyzeSecurity",
        "title": "VibeGuard: Security Scan Only",
        "icon": "$(search)"
      },
      {
        "command": "vibeguard.profile",
        "title": "VibeGuard: Profile in Sandbox",
        "icon": "$(pulse)"
      },
      {
        "command": "vibeguard.analyzeSelection",
        "title": "VibeGuard: Analyze Selection",
        "icon": "$(selection)"
      },
      {
        "command": "vibeguard.openChat",
        "title": "VibeGuard: Open Secure Code Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "vibeguard.openChatPanel",
        "title": "VibeGuard: Open Chat in Editor Panel",
        "icon": "$(layout-panel)"
      },
      {
        "command": "vibeguard.checkHealth",
        "title": "VibeGuard: Check API Health",
        "icon": "$(heart)"
      },
      {
        "command": "vibeguard.fix",
        "title": "VibeGuard: Auto-Fix File",
        "icon": "$(wrench)"
      },
      {
        "command": "vibeguard.compare",
        "title": "VibeGuard: Compare Before/After Fix",
        "icon": "$(diff)"
      },
      {
        "command": "vibeguard.explainFinding",
        "title": "Explain in VibeGuard Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "vibeguard.navigateToFinding",
        "title": "Go to Finding",
        "icon": "$(go-to-file)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vibeguard",
          "title": "VibeGuard",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "vibeguard": [
        {
          "id": "vibeguard.findingsView",
          "name": "Findings",
          "icon": "media/icon.svg"
        },
        {
          "type": "webview",
          "id": "vibeguard.chatView",
          "name": "Secure Code Chat",
          "icon": "media/icon.svg"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "vibeguard.analyze",
          "when": "editorLangId == python",
          "group": "vibeguard@1"
        },
        {
          "command": "vibeguard.analyzeSelection",
          "when": "editorLangId == python && editorHasSelection",
          "group": "vibeguard@2"
        },
        {
          "command": "vibeguard.openChat",
          "when": "editorLangId == python",
          "group": "vibeguard@3"
        },
        {
          "command": "vibeguard.fix",
          "when": "editorLangId == python",
          "group": "vibeguard@4"
        },
        {
          "command": "vibeguard.compare",
          "when": "editorLangId == python",
          "group": "vibeguard@5"
        }
      ],
      "view/item/context": [
        {
          "command": "vibeguard.explainFinding",
          "when": "view == vibeguard.findingsView && viewItem == finding",
          "group": "inline"
        },
        {
          "command": "vibeguard.navigateToFinding",
          "when": "view == vibeguard.findingsView && viewItem == finding",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "vibeguard.analyze",
          "when": "editorLangId == python"
        },
        {
          "command": "vibeguard.analyzeSecurity",
          "when": "editorLangId == python"
        },
        {
          "command": "vibeguard.profile",
          "when": "editorLangId == python"
        },
        {
          "command": "vibeguard.analyzeSelection",
          "when": "editorLangId == python"
        },
        {
          "command": "vibeguard.openChat"
        },
        {
          "command": "vibeguard.openChatPanel"
        },
        {
          "command": "vibeguard.checkHealth"
        },
        {
          "command": "vibeguard.fix",
          "when": "editorLangId == python"
        },
        {
          "command": "vibeguard.compare",
          "when": "editorLangId == python"
        },
        {
          "command": "vibeguard.explainFinding",
          "when": "false"
        },
        {
          "command": "vibeguard.navigateToFinding",
          "when": "false"
        }
      ]
    },
    "walkthroughs": [
      {
        "id": "vibeguard.gettingStarted",
        "title": "Getting Started with VibeGuard",
        "description": "Scan, fix, and generate secure Python code.",
        "steps": [
          {
            "id": "checkHealth",
            "title": "1. Verify the APIs are running",
            "description": "VibeGuard relies on three local API servers. Make sure they are running, then check connectivity.\n[Check API Health](command:vibeguard.checkHealth)",
            "media": { "image": "media/icon.svg", "altText": "VibeGuard icon" },
            "completionEvents": ["onCommand:vibeguard.checkHealth"]
          },
          {
            "id": "firstScan",
            "title": "2. Scan a Python file",
            "description": "Open any Python file and run a security + sandbox analysis. Findings appear as squiggles in the editor and in the **Findings** panel in the sidebar.\n[Analyze File](command:vibeguard.analyze)",
            "media": { "image": "media/icon.svg", "altText": "VibeGuard icon" },
            "completionEvents": ["onCommand:vibeguard.analyze"]
          },
          {
            "id": "reviewFindings",
            "title": "3. Review findings in the sidebar",
            "description": "Open the **VibeGuard** sidebar (shield icon in the Activity Bar). The **Findings** panel shows all issues grouped by severity. Hover over a squiggle for detail, or click a finding to jump to its line.",
            "media": { "image": "media/icon.svg", "altText": "VibeGuard icon" }
          },
          {
            "id": "applyFix",
            "title": "4. Preview and apply auto-fixes",
            "description": "VibeGuard can fix some issues automatically. A diff editor opens so you can review every change before it is written to your file.\n[Auto-Fix File](command:vibeguard.fix)",
            "media": { "image": "media/icon.svg", "altText": "VibeGuard icon" },
            "completionEvents": ["onCommand:vibeguard.fix"]
          },
          {
            "id": "secureChat",
            "title": "5. Generate secure code with chat",
            "description": "Use the **Secure Code Chat** in the sidebar to ask for Python code. VibeGuard scans each response and re-prompts the model until the output passes its security rules. You can also right-click any finding squiggle and choose **Explain in VibeGuard Chat**.\n[Open Chat](command:vibeguard.openChat)",
            "media": { "image": "media/icon.svg", "altText": "VibeGuard icon" },
            "completionEvents": ["onCommand:vibeguard.openChat"]
          }
        ]
      }
    ],
    "keybindings": [
      {
        "command": "vibeguard.fix",
        "key": "ctrl+shift+f",
        "mac": "cmd+shift+f",
        "when": "editorLangId == python"
      },
      {
        "command": "vibeguard.analyze",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "editorLangId == python"
      }
    ],
    "configuration": {
      "title": "VibeGuard",
      "properties": {
        "vibeguard.securityApiUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8000",
          "description": "Base URL for the VibeGuard static security analyzer API."
        },
        "vibeguard.sandboxApiUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8001",
          "description": "Base URL for the VibeGuard Python profiling sandbox API."
        },
        "vibeguard.orchestratorApiUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8002",
          "description": "Base URL for the VibeGuard orchestrator (fix, compare, secure chat)."
        },
        "vibeguard.chatProvider": {
          "type": "string",
          "enum": ["openai", "ollama", "anthropic"],
          "default": "openai",
          "description": "LLM provider for secure code chat (requires matching API env on orchestrator host)."
        },
        "vibeguard.chatModel": {
          "type": "string",
          "default": "gpt-4o-mini",
          "description": "Model name passed to the chat provider."
        },
        "vibeguard.chatRefine": {
          "type": "boolean",
          "default": true,
          "description": "Re-prompt the LLM when generated code still violates VibeGuard security rules."
        },
        "vibeguard.chatMaxIterations": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 5,
          "description": "Maximum refine rounds for secure code chat."
        },
        "vibeguard.minSeverity": {
          "type": "string",
          "enum": [
            "INFO",
            "LOW",
            "MEDIUM",
            "HIGH",
            "CRITICAL"
          ],
          "default": "LOW",
          "description": "Minimum severity reported from the security analyzer."
        },
        "vibeguard.runSandboxOnAnalyze": {
          "type": "boolean",
          "default": true,
          "description": "When running full analyze, also profile code in the sandbox."
        },
        "vibeguard.requestTimeoutMs": {
          "type": "number",
          "default": 60000,
          "minimum": 5000,
          "description": "HTTP request timeout in milliseconds."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npm run compile && npx @vscode/vsce@2.32.0 package --no-dependencies --allow-missing-repository"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.3"
  }
}
