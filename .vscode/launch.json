{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Vibeguard: Scan file",
      "type": "debugpy",
      "request": "launch",
      "module": "security.cli.main",
      "args": ["scan", "${file}"],
      "cwd": "${workspaceFolder}",
      "justMyCode": true
    },
    {
      "name": "Pytest: Current file",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["${file}", "-v"],
      "cwd": "${workspaceFolder}",
      "justMyCode": false
    },
    {
      "name": "Pytest: All tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests/", "-v"],
      "cwd": "${workspaceFolder}",
      "justMyCode": false
    },
    {
      "name": "Security API",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["security.api.main:app", "--port", "8000", "--reload"],
      "cwd": "${workspaceFolder}",
      "justMyCode": true
    },
    {
      "name": "Sandbox API",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["sandbox.main:app", "--port", "8001", "--reload"],
      "cwd": "${workspaceFolder}",
      "justMyCode": true
    },
    {
      "name": "Orchestrator API",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["orchestrator.main:app", "--port", "8002", "--reload"],
      "cwd": "${workspaceFolder}",
      "justMyCode": true
    }
  ]
}
